# ─── Server (crates/server) ────────────────────────────────────────────────
# Required. Admin login password for the dashboard at /admin/login.
ADMIN_PASSWORD=change-me

# Optional. Username paired with ADMIN_PASSWORD.
ADMIN_USERNAME=admin

# Optional. Bearer token required by /api/sources/pending and /api/articles/ingest.
# If unset, those endpoints return 503 — set this whenever you run the local client.
API_TOKEN=

# Optional. SQLite connection string.
DATABASE_URL=sqlite:data.db?mode=rwc

# Optional. RSS feed-fetch cron period in minutes.
FETCH_INTERVAL_MINUTES=30

# Optional. Drop source articles whose Published date is older than this many
# days from the pool the LLM sees. NULL/unparseable dates are still allowed through.
MAX_SOURCE_AGE_DAYS=30

# Optional. Bind address.
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# ─── Server, only with `--features server-llm` ─────────────────────────────
# These are read only when the optional server-side generation feature is on.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2:latest
# GENERATE_INTERVAL_HOURS=2

# ─── Client (crates/client) ────────────────────────────────────────────────
# Required. URL of the running server (no trailing slash needed).
SERVER_URL=http://localhost:3000

# Required. Must match the server's API_TOKEN above.
# (Reuse the same variable — both binaries read API_TOKEN.)

# Optional. Where to reach Ollama for local generation.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
